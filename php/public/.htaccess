# MOLGANG dapp — serve static files directly, route /api/* to the PHP front controller.
RewriteEngine On

# Defence in depth FIRST: block the engine sources, schema and config over HTTP. These
# must run BEFORE the static passthrough below, otherwise an on-disk src/*.php is served
# (executed as an empty script) instead of being denied. Refs #61 #62 #63.
RewriteRule ^(\.\.|config\.php|src/|.*\.sql|.*\.bak.*)$ - [F]
RewriteRule ^src/ - [F]

# Existing files/dirs (index.html, app.js, style.css, avatars/*) are served as-is.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything under api/ goes to the front controller (query string preserved).
RewriteRule ^api/ index.php [QSA,L]

DirectoryIndex index.html

# Belt-and-braces: deny config + the src/ engine via Files/Directory directives too.
<FilesMatch "^config\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "\.(sql|bak)$">
  Require all denied
</FilesMatch>
